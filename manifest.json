{
  "manifest_version": 3,
  "name": "ChatGPT Wiretapper",
  "version": "1.0.0",
  "description": "Audit ChatGPT's hidden search intent routing, decode the autocomplete layer, and reverse-engineer real-time web citations.",
  "permissions": [
    "webRequest"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://chatgpt.com/*"
      ]
    }
  ]
}